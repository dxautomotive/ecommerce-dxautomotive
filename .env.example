# ┌─────────────────────────────────────────────────────────────────┐
# │  DX Automotive — variáveis de ambiente do Docker Compose (DEV)  │
# │                                                                 │
# │  Copie este arquivo para `.env` e ajuste os valores.            │
# │  As envs específicas dos apps ficam em:                         │
# │    apps/backend/.env       (Medusa: DB, Redis, JWT, MercadoPago)│
# │    apps/storefront/.env.local  (Next: backend URL, WhatsApp...) │
# └─────────────────────────────────────────────────────────────────┘

# ─── PostgreSQL (container `dx-automotive-postgres`) ──────────────
# Portas não-padrão para coexistir com outros projetos no mesmo host.
POSTGRES_USER=medusa
POSTGRES_PASSWORD=trocar_em_producao
POSTGRES_DB=dx_automotive
POSTGRES_PORT=5434

# ─── Redis (container `dx-automotive-redis`) ──────────────────────
REDIS_PORT=6381

# ─── Connection strings (referência — usar em apps/backend/.env) ──
# DATABASE_URL=postgresql://medusa:<senha>@localhost:5434/dx_automotive
# REDIS_URL=redis://localhost:6381
